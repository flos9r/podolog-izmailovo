# ─── Database ────────────────────────────────────────────
# SQLite for development. For production, migrate to PostgreSQL.
DATABASE_URL="file:./dev.db"

# ─── Auth ────────────────────────────────────────────────
# Secret for session encryption. MUST be changed in production (min 32 chars).
AUTH_SECRET="change-me-in-production-to-random-string-at-least-32-chars"

# ─── Default admin (used only by seed script) ───────────
ADMIN_EMAIL="admin@podolog.ru"
ADMIN_PASSWORD="admin123"
