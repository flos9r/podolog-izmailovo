# ─── Database ────────────────────────────────────────────
# SQLite — relative to prisma/ directory.
# Local development:
DATABASE_URL="file:./dev.db"
# Docker production (persistent volume):
# DATABASE_URL="file:/app/data/production.db"

# ─── Auth ────────────────────────────────────────────────
# Secret for session encryption (min 32 chars).
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-to-random-string-at-least-32-chars"

# ─── Default admin (used only by seed script) ───────────
ADMIN_EMAIL="admin@podolog.ru"
ADMIN_PASSWORD="admin123"
