# ─── Database ────────────────────────────────────────────
# For Docker: use /app/data/production.db for persistent volume
DATABASE_URL="file:/app/data/production.db"

# ─── Auth ────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"

# ─── Default admin (used only by seed on first run) ─────
ADMIN_EMAIL="admin@podolog.ru"
ADMIN_PASSWORD="CHANGE-ME-use-strong-password"
